{
  "name": "mcp-animation-inspector",
  "version": "0.1.0",
  "description": "MCP server that helps AI assistants understand website animations via Playwright, pluggable detectors, and frame capture",
  "type": "module",
  "bin": {
    "mcp-animation-inspector": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js"
  },
  "keywords": [
    "mcp",
    "animation",
    "playwright",
    "inspector",
    "ai",
    "claude"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ak0096/mcp-animation-inspector.git"
  },
  "homepage": "https://github.com/Ak0096/mcp-animation-inspector#readme",
  "bugs": {
    "url": "https://github.com/Ak0096/mcp-animation-inspector/issues"
  },
  "author": "Ak0096",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "playwright": "^1.52.0",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
